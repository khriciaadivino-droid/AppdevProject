# Copy to .env for local development. On Railway, set these in the service Variables tab.

PORT=9000
JWT_SECRET=change-me-in-production

# Full Firebase service account JSON as a single line (Railway variable).
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Database: on Railway link MySQL plugin, set USE_MYSQL=true, then reference vars:
#   MYSQLHOST → MYSQL_HOST, MYSQLPORT → MYSQL_PORT, MYSQLUSER → MYSQL_USER,
#   MYSQLPASSWORD → MYSQL_PASSWORD, MYSQLDATABASE → MYSQL_DATABASE
# Or set DATABASE_URL from the MySQL service. Do not use 127.0.0.1 on Railway.
USE_MYSQL=false
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_DATABASE=
# MYSQL_USER=
# MYSQL_PASSWORD=
# DATABASE_URL=
