# Copy to .env for local development. On Railway, set these in the service Variables tab.

PORT=9000
JWT_SECRET=change-me-in-production

# Full Firebase service account JSON as a single line (Railway variable).
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Database: link MySQL plugin in Railway, then add reference variables (one value each):
#   MYSQL_HOST     = ${{MySQL.MYSQLHOST}}
#   MYSQL_PORT     = ${{MySQL.MYSQLPORT}}
#   MYSQL_USER     = ${{MySQL.MYSQLUSER}}
#   MYSQL_PASSWORD = ${{MySQL.MYSQLPASSWORD}}
#   MYSQL_DATABASE = ${{MySQL.MYSQLDATABASE}}
# Or DATABASE_URL = ${{MySQL.DATABASE_URL}}
# Do NOT paste mysql.railway.internal twice into MYSQL_HOST.
# If MySQL is linked, you can omit USE_MYSQL (auto-detected). Set USE_MYSQL=false to force SQLite.
USE_MYSQL=false
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_DATABASE=
# MYSQL_USER=
# MYSQL_PASSWORD=
# DATABASE_URL=
