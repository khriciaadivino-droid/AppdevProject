# Copy to .env for local development. On Railway, set these in the service Variables tab.

PORT=9000
JWT_SECRET=change-me-in-production

# Full Firebase service account JSON as a single line (Railway variable).
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Database: SQLite by default. Set USE_MYSQL=true and MySQL vars for production.
USE_MYSQL=false
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_DATABASE=
# MYSQL_USER=
# MYSQL_PASSWORD=
