# Copy to .env for local development. On Railway, set these in the service Variables tab.

PORT=9000
JWT_SECRET=change-me-in-production

# Full Firebase service account JSON as a single line (Railway variable).
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Database: on Railway prefer MySQL (link MySQL plugin, set USE_MYSQL=true).
# SQLite needs native rebuild in Docker; do not upload local node_modules.
USE_MYSQL=false
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_DATABASE=
# MYSQL_USER=
# MYSQL_PASSWORD=
